# Example environment variables. Copy to .env.local (gitignored) and fill in.
# NOT exhaustive — this starter documents the admin-auth vars; other features
# (Supabase, Sanity, Algolia, Mailgun, PostHog, feedback IP salt, etc.) need
# their own vars. Placeholders only — never commit real secret values.

# --- Admin area auth ---------------------------------------------------------
# Shared password for the /admin login.
ADMIN_PASSWORD=change-me
# Per-deployment secret used to derive the admin session cookie via scrypt.
# Generate with:  openssl rand -hex 32
# Must be set in every environment (Vercel prod/preview + local) or admin auth
# fails closed (no one can log in).
ADMIN_AUTH_SECRET=generate-a-64-char-hex-string
